{
  "name": "nova-facture",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node prisma/prepare.js && next dev",
    "build": "node prisma/prepare.js && prisma db push --accept-data-loss && tsx src/lib/seed.ts && next build",
    "start": "next start",
    "lint": "eslint",
    "seed": "tsx src/lib/seed.ts",
    "db:migrate": "node prisma/prepare.js && prisma migrate deploy",
    "db:seed": "tsx src/lib/seed.ts",
    "postinstall": "node prisma/prepare.js && prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^6.19.3",
    "@react-pdf/renderer": "^4.5.1",
    "bcrypt": "^6.0.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5"
  }
}
